# PolyBot Configuration
# Copy this to .env and fill in your values.
# For GitHub Actions: add these as repository secrets instead of using .env.
#
# Variables marked [REQUIRED] must be set for the bot to function.
# Variables marked [OPTIONAL] enable additional features.

# ─── Required ────────────────────────────────────────────────────────────────

# [REQUIRED] Your Polygon wallet private key (with 0x prefix).
# Used for signing live trades. Keep this secret — never commit to git.
PRIVATE_KEY=

# [REQUIRED] Your Polygon wallet address (public, used for balance checks).
FUNDER_ADDRESS=

# [OPTIONAL] Set to "false" to enable live trading. Default: true (paper trading).
DRY_RUN=true

# ─── Capital ─────────────────────────────────────────────────────────────────

# [OPTIONAL] Starting capital in USD. Used for P&L tracking in dry-run mode.
# Default: 100
INITIAL_CAPITAL=100

# ─── Discord Alerts (Recommended) ────────────────────────────────────────────

# [OPTIONAL] Discord webhook URL for real-time trade and PnL alerts.
# Create one in: Discord → Server → Channel Settings → Integrations → Webhooks
# If not set, all Discord alerts are silently skipped.
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ─── Telegram Alerts (DEPRECATED — use Discord instead) ──────────────────────

# Telegram alerts are no longer actively developed. Switch to DISCORD_WEBHOOK_URL.
# These variables are kept for backward compatibility only.
# TELEGRAM_BOT_TOKEN=   # From @BotFather on Telegram
# TELEGRAM_CHAT_ID=     # Your chat ID (get from @userinfobot)

# ─── AI Forecaster (Optional) ────────────────────────────────────────────────

# [OPTIONAL] OpenAI API key for the AI forecasting strategy.
# Without this, the AIForecasterStrategy is automatically disabled.
OPENAI_API_KEY=

# [OPTIONAL] OpenAI model to use. Default: gpt-4o-mini
AI_MODEL=gpt-4o-mini

# ─── Weather Data (Optional) ─────────────────────────────────────────────────

# [OPTIONAL] NOAA API token. Open-Meteo is used by default and requires no key.
# Only set this if you want NOAA weather data as an additional source.
NOAA_API_TOKEN=

# ─── Kalshi Cross-Platform Arbitrage (Optional) ───────────────────────────────

# [OPTIONAL] Kalshi API credentials for cross-platform arbitrage strategy.
# Without these, cross-platform arb is disabled.
KALSHI_API_KEY=
KALSHI_API_SECRET=

# ─── Sports Data (Optional) ──────────────────────────────────────────────────

# [OPTIONAL] The Odds API key for sports intelligence strategy.
# https://the-odds-api.com/
ODDS_API_KEY=
